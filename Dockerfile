# ===============================
# 🚀 BASE IMAGE
# ===============================
FROM node:20-alpine

# ===============================
# 📁 WORKDIR
# ===============================
WORKDIR /app

# ===============================
# 📦 COPY PACKAGE
# ===============================
COPY package*.json ./

# ===============================
# 📥 INSTALL DEPENDENCY
# ===============================
RUN npm install --omit=dev

# ===============================
# 📁 COPY SOURCE
# ===============================
COPY . .

# ===============================
# 📂 CREATE UPLOAD DIR
# ===============================
RUN mkdir -p uploads

# ===============================
# 🌐 EXPOSE PORT
# ===============================
EXPOSE 3000

# ===============================
# ▶️ START APP
# ===============================
CMD ["node", "src/index.js"]